<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>RWikiStat API Docs</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/geist-sans@5.1.1/index.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/geist-mono@5.1.1/index.css">
  <style>
    :root {
      --bg: #f8f9fa;
      --surface: #fff;
      --surface-hover: #f1f3f5;
      --border: #e9ecef;
      --text: #212529;
      --text-secondary: #6c757d;
      --text-muted: #adb5bd;
      --brand: #00726B;
      --brand-light: #e6f5f4;
      --get: #0d6efd;
      --post: #198754;
      --put: #ffc107;
      --patch: #fd7e14;
      --del: #dc3545;
      --shadow: 0 1px 3px rgba(0, 0, 0, .06), 0 1px 2px rgba(0, 0, 0, .04);
      --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, .06);
      --radius: 10px;
      --radius-sm: 4px;
      --ff: 'Geist Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      --fm: 'Geist Mono', 'SF Mono', 'Fira Code', 'Consolas', monospace;
      --nav-w: 250px;
      --h: 56px
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0
    }

    html {
      scroll-behavior: smooth
    }

    body {
      font-family: var(--ff);
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      display: flex;
      min-height: 100vh
    }

    /* Sidebar */
    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: var(--nav-w);
      background: var(--surface);
      border-right: 1px solid var(--border);
      overflow-y: auto;
      z-index: 100;
      display: flex;
      flex-direction: column
    }

    .sidebar-brand {
      padding: 1.25rem 1.25rem 1rem;
      border-bottom: 1px solid var(--border)
    }

    .sidebar-brand .brand-icon {
      width: 32px;
      height: 32px;
      background: var(--brand);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-weight: 600;
      font-size: .85rem;
      margin-bottom: .6rem
    }

    .sidebar-brand h1 {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text);
      letter-spacing: -.01em
    }

    .sidebar-brand p {
      font-size: .72rem;
      color: var(--text-muted);
      margin-top: 1px
    }

    .sidebar-nav {
      flex: 1;
      padding: .5rem 0;
      overflow-y: auto
    }

    .sidebar-nav a {
      display: flex;
      align-items: center;
      gap: .5rem;
      padding: .45rem 1.25rem;
      font-size: .8rem;
      color: var(--text-secondary);
      text-decoration: none;
      border-left: 3px solid transparent;
      transition: all .12s
    }

    .sidebar-nav a:hover {
      color: var(--text);
      background: var(--surface-hover)
    }

    .sidebar-nav a.active {
      color: var(--brand);
      border-left-color: var(--brand);
      background: var(--brand-light);
      font-weight: 500
    }

    .sidebar-nav a .nav-icon {
      font-size: .65rem;
      color: var(--text-muted);
      width: 14px;
      text-align: center;
      flex-shrink: 0
    }

    .sidebar-nav a:hover .nav-icon {
      color: var(--text-secondary)
    }

    .sidebar-nav a.active .nav-icon {
      color: var(--brand)
    }

    .sidebar-nav a .badge {
      margin-left: auto;
      font-size: .6rem;
      color: var(--text-muted);
      background: var(--surface-hover);
      padding: .1rem .45rem;
      border-radius: 6px;
      font-weight: 500
    }

    .sidebar-footer {
      padding: .75rem 1.25rem;
      border-top: 1px solid var(--border);
      font-size: .68rem;
      color: var(--text-muted);
      font-family: var(--fm);
      letter-spacing: -.01em
    }

    /* Sidebar scrollbar */
    .sidebar::-webkit-scrollbar {
      width: 4px
    }

    .sidebar::-webkit-scrollbar-thumb {
      background: var(--border);
      border-radius: 2px
    }

    /* Main */
    .main {
      margin-left: var(--nav-w);
      flex: 1;
      min-width: 0
    }

    .header {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(255, 255, 255, .85);
      -webkit-backdrop-filter: blur(12px);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      height: var(--h);
      display: flex;
      align-items: center;
      gap: .75rem
    }

    .header .page-title {
      font-size: .92rem;
      font-weight: 500;
      color: var(--text);
      letter-spacing: -.01em
    }

    .header .page-sub {
      font-size: .78rem;
      color: var(--text-muted);
      margin-left: auto
    }

    .content {
      padding: 2rem;
      max-width: 1100px;
      margin: 0 auto
    }

    /* Base URL box */
    .base-box {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.5rem;
      margin-bottom: 2.5rem;
      box-shadow: var(--shadow)
    }

    .base-box h2 {
      font-size: .72rem;
      text-transform: uppercase;
      letter-spacing: .5px;
      color: var(--text-muted);
      margin-bottom: 1rem
    }

    .base-urls {
      display: flex;
      flex-direction: column;
      gap: .5rem
    }

    .base-urls .item {
      display: flex;
      align-items: center;
      gap: .75rem;
      font-family: var(--fm);
      font-size: .85rem
    }

    .base-urls .item .tag {
      font-size: .62rem;
      font-weight: 500;
      padding: .15rem .5rem;
      border-radius: var(--radius-sm);
      text-transform: uppercase;
      color: #fff;
      min-width: 40px;
      text-align: center
    }

    .tag-local {
      background: #495057
    }

    .tag-dev {
      background: #fd7e14
    }

    .tag-prod {
      background: #dc3545
    }

    .base-box .note {
      margin-top: .75rem;
      font-size: .78rem;
      color: var(--text-secondary)
    }

    .base-box .note code {
      font-family: var(--fm);
      font-size: .74rem;
      background: var(--surface-hover);
      padding: .1rem .35rem;
      border-radius: var(--radius-sm)
    }

    /* Sections */
    section {
      margin-bottom: 3rem;
      opacity: 0;
      transform: translateY(16px);
      transition: opacity .5s ease, transform .5s ease
    }

    section.visible {
      opacity: 1;
      transform: translateY(0)
    }

    section h2 {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--brand);
      display: flex;
      align-items: center;
      gap: .5rem;
      margin-bottom: .35rem
    }

    section h2 .count {
      background: var(--surface-hover);
      color: var(--text-muted);
      font-size: .68rem;
      font-weight: 500;
      padding: .1rem .5rem;
      border-radius: 8px
    }

    section>p {
      color: var(--text-secondary);
      font-size: .82rem;
      margin-bottom: 1rem
    }

    /* Table */
    .wrap {
      overflow-x: auto;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow)
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: .82rem;
      min-width: 700px
    }

    thead {
      position: sticky;
      top: 0;
      z-index: 2
    }

    th {
      background: var(--surface);
      font-weight: 500;
      text-align: left;
      padding: .6rem .85rem;
      border-bottom: 2px solid var(--border);
      white-space: nowrap;
      color: var(--text-secondary);
      font-size: .72rem;
      text-transform: uppercase;
      letter-spacing: .3px
    }

    td {
      padding: .5rem .85rem;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
      transition: background .12s
    }

    tr:last-child td {
      border-bottom: none
    }

    tbody tr {
      cursor: default
    }

    tbody tr:hover td {
      background: var(--surface-hover)
    }

    .method {
      display: inline-block;
      font-weight: 500;
      font-size: .68rem;
      padding: .14rem .48rem;
      border-radius: var(--radius-sm);
      text-transform: uppercase;
      min-width: 44px;
      text-align: center;
      color: #fff;
      font-family: var(--fm)
    }

    .get {
      background: var(--get)
    }

    .post {
      background: var(--post)
    }

    .put {
      background: var(--put);
      color: #333
    }

    .patch {
      background: var(--patch)
    }

    .delete {
      background: var(--del)
    }

    .ep {
      font-family: var(--fm);
      font-size: .78rem;
      color: var(--text);
      word-break: break-all
    }

    .ep-copy {
      position: relative
    }

    .ep-copy .copy-btn {
      opacity: 0;
      position: absolute;
      right: 2px;
      top: 2px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 2px 6px;
      font-size: .62rem;
      cursor: pointer;
      color: var(--text-muted);
      transition: opacity .12s;
      font-family: var(--ff)
    }

    .ep-copy:hover .copy-btn {
      opacity: 1
    }

    .ep-copy .copy-btn:hover {
      background: var(--surface-hover);
      color: var(--text)
    }

    td code {
      font-family: var(--fm);
      font-size: .74rem;
      background: var(--surface-hover);
      padding: .08rem .3rem;
      border-radius: var(--radius-sm);
      color: var(--brand)
    }

    .na {
      color: var(--text-muted);
      font-size: .76rem
    }

    .nb {
      color: var(--get);
      font-size: .76rem;
      font-weight: 500
    }

    .adm {
      color: var(--del);
      font-size: .76rem;
      font-weight: 500
    }

    .desc {
      color: var(--text-secondary);
      font-size: .78rem
    }

    /* Toast */
    .toast {
      position: fixed;
      bottom: 1.25rem;
      right: 1.25rem;
      z-index: 999;
      background: var(--text);
      color: var(--bg);
      padding: .5rem 1rem;
      border-radius: var(--radius);
      font-size: .78rem;
      opacity: 0;
      transform: translateY(8px);
      transition: all .25s;
      pointer-events: none
    }

    .toast.show {
      opacity: 1;
      transform: translateY(0)
    }

    /* Mobile nav */
    .mobile-nav {
      display: none;
      position: sticky;
      top: var(--h);
      z-index: 45;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      overflow-x: auto;
      padding: .35rem .75rem
    }

    .mobile-nav a {
      display: inline-block;
      white-space: nowrap;
      text-decoration: none;
      font-size: .76rem;
      color: var(--text-secondary);
      padding: .25rem .6rem;
      border-radius: var(--radius-sm)
    }

    .mobile-nav a:hover {
      background: var(--surface-hover);
      color: var(--text)
    }

    .footer {
      text-align: center;
      padding: 2rem;
      color: var(--text-muted);
      font-size: .78rem;
      border-top: 1px solid var(--border);
      margin-top: 2rem
    }

    /* Animations */
    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(12px)
      }

      to {
        opacity: 1;
        transform: translateY(0)
      }
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateX(-8px)
      }

      to {
        opacity: 1;
        transform: translateX(0)
      }
    }

    .header {
      animation: fadeUp .4s ease
    }

    .base-box {
      animation: fadeUp .45s .1s both
    }

    .sidebar-brand {
      animation: slideIn .35s .05s both
    }

    @media(max-width:900px) {
      .sidebar {
        display: none
      }

      .main {
        margin-left: 0
      }

      .mobile-nav {
        display: flex;
        gap: .25rem
      }

      .content {
        padding: 1.25rem
      }

      .header {
        padding: 0 1rem
      }
    }

    @media(max-width:600px) {
      .content {
        padding: 1rem
      }

      td,
      th {
        padding: .35rem .5rem;
        font-size: .74rem
      }

      .ep {
        font-size: .72rem
      }
    }
  </style>
</head>

<body>

  <aside class="sidebar" role="navigation">
    <div class="sidebar-brand">

      <h1>RWikiStat API</h1>
      <p>Dokumentasi endpoint</p>
    </div>
    <div class="sidebar-nav">
      <a href="#base-url" data-nav>
        <span class="nav-icon">◆</span> BASE_URL
      </a>
      <% groups.forEach(g=> { %>
        <a href="#<%= g.prefix.replace('/','') %>" data-nav>
          <span class="nav-icon">▸</span>
          <%= g.prefix %>
            <span class="badge">
              <%= g.endpoints.length %>
            </span>
        </a>
        <% }) %>
    </div>
  </aside>

  <div class="main">
    <header class="header">
      <span class="page-title">API Documentation</span>
      <span class="page-sub">
        <%= groups.reduce((a,g)=> a + g.endpoints.length, 0) %> endpoints
      </span>
    </header>

    <nav class="mobile-nav">
      <a href="#base-url">BASE_URL</a>
      <% groups.forEach(g=> { %>
        <a href="#<%= g.prefix.replace('/','') %>">
          <%= g.prefix %>
        </a>
        <% }) %>
    </nav>

    <div class="content">

      <div class="base-box" id="base-url">
        <h2>Base URL</h2>
        <div class="base-urls">
          <div class="item"><span class="tag tag-local">LOCAL</span> <code>http://localhost:8080</code></div>
          <div class="item"><span class="tag tag-dev">DEV</span> <code>http://127.0.0.1:8080</code></div>
          <div class="item"><span class="tag tag-prod">PROD</span> <code>https://api.rwikistat.com</code></div>
        </div>
        <p class="note">Semua endpoint ditulis dengan prefix <code>/api/...</code>. Ganti BASE_URL sesuai lingkungan.
        </p>
      </div>

      <% groups.forEach(g=> { %>
        <section id="<%= g.prefix.replace('/','') %>">
          <h2>
            <%= g.prefix %> <span class="count">
                <%= g.endpoints.length %>
              </span>
          </h2>
          <p>
            <%= g.desc %>
          </p>
          <div class="wrap">
            <table>
              <thead>
                <tr>
                  <th>Method</th>
                  <th>Endpoint</th>
                  <th>Auth</th>
                  <th>Body</th>
                  <% if (g.endpoints.some(e=> e.params)) { %><th>Params</th>
                    <% } %>
                      <% if (g.endpoints.some(e=> e.query)) { %><th>Query</th>
                        <% } %>
                          <th>Deskripsi</th>
                </tr>
              </thead>
              <tbody>
                <% g.endpoints.forEach(e=> { %>
                  <tr>
                    <td><span class="method <%= e.method.toLowerCase() %>">
                        <%= e.method %>
                      </span></td>
                    <td class="ep ep-copy">
                      <%= e.path %><button class="copy-btn" data-copy="<%= e.path %>">Salin</button>
                    </td>
                    <td>
                      <% if (e.auth==='None' ) { %><span class="na">None</span>
                        <% } else if (e.auth==='Admin' ) { %><span class="adm">Admin</span>
                          <% } else { %><span class="nb">Bearer</span>
                            <% } %>
                    </td>
                    <td>
                      <%= e.body %>
                    </td>
                    <% if (g.endpoints.some(x=> x.params)) { %><td>
                        <%= e.params || '—' %>
                      </td>
                      <% } %>
                        <% if (g.endpoints.some(x=> x.query)) { %><td>
                            <%= e.query || '—' %>
                          </td>
                          <% } %>
                            <td class="desc">
                              <%= e.desc %>
                            </td>
                  </tr>
                  <% }) %>
              </tbody>
            </table>
          </div>
        </section>
        <% }) %>

    </div>
  </div>

  <div class="toast" id="toast"></div>

  <script>
    (function () {
      var sections = document.querySelectorAll('section');
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) { if (e.isIntersecting) e.target.classList.add('visible') });
      }, { threshold: 0.1 });
      sections.forEach(function (s) { obs.observe(s) });

      var navLinks = document.querySelectorAll('[data-nav]');
      var allAnchors = Array.from(document.querySelectorAll('section[id]'));
      function onScroll() {
        var scrollY = window.scrollY + 120;
        var activeId = '';
        allAnchors.forEach(function (s) { if (s.offsetTop <= scrollY) activeId = s.id; });
        navLinks.forEach(function (a) {
          a.classList.toggle('active', a.getAttribute('href') === '#' + activeId);
        });
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      var toast = document.getElementById('toast');
      document.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-copy]');
        if (!btn) return;
        navigator.clipboard.writeText(btn.getAttribute('data-copy')).then(function () {
          toast.textContent = 'Disalin!';
          toast.classList.add('show');
          setTimeout(function () { toast.classList.remove('show') }, 1500);
        });
      });
    })();
  </script>
</body>

</html>